{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 20, "patch": 0 },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_CXX_STANDARD": "20",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_INSTALL_PREFIX": "$env{HOME}/.local",
                "CMAKE_PREFIX_PATH": "$env{HOME}/.local"
            }
        },
        {
            "name": "pi-release",
            "inherits": "base",
            "displayName": "Pi 5 (ARM64 Linux) Release",
            "description": "Raspberry Pi 5 build — Release",
            "binaryDir": "${sourceDir}/build",
            "generator": "Unix Makefiles",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_TOOLCHAIN_FILE": "$env{HOME}/vcpkg/scripts/buildsystems/vcpkg.cmake"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "pi-debug",
            "inherits": "pi-release",
            "displayName": "Pi 5 (ARM64 Linux) Debug",
            "description": "Raspberry Pi 5 build — Debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "windows-base",
            "hidden": true,
            "inherits": "base",
            "generator": "Visual Studio 17 2022",
            "architecture": {
                "value": "x64",
                "strategy": "set"
            },
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "$env{USERPROFILE}/.local",
                "CMAKE_PREFIX_PATH": "$env{USERPROFILE}/.local",
                "CMAKE_TOOLCHAIN_FILE": "$env{USERPROFILE}/Projects/cppenv/vcpkg/scripts/buildsystems/vcpkg.cmake",
                "CMAKE_CXX_FLAGS": "/D_USE_MATH_DEFINES /DNOMINMAX /D_SILENCE_STDEXT_ARR_ITERS_DEPRECATION_WARNING /EHsc /D_WIN32_WINNT=0x0A00",
                "CMAKE_FIND_PACKAGE_PREFER_CONFIG": "ON"
            },
            "environment": {
                "VCPKG_OVERLAY_PORTS": "${sourceDir}/vcpkg-overlay",
                "VCPKG_BINARY_SOURCES": "clear;nuget,http://localhost:3000/api/packages/pkgmanager/nuget/index.json,readwrite"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "windows-release",
            "inherits": "windows-base",
            "displayName": "Windows x64 Release",
            "description": "Windows Visual Studio build — Release",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "windows-debug",
            "inherits": "windows-base",
            "displayName": "Windows x64 Debug",
            "description": "Windows Visual Studio build — Debug",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "pi-release",
            "configurePreset": "pi-release"
        },
        {
            "name": "pi-debug",
            "configurePreset": "pi-debug"
        },
        {
            "name": "windows-release",
            "configurePreset": "windows-release",
            "configuration": "Release"
        },
        {
            "name": "windows-debug",
            "configurePreset": "windows-debug",
            "configuration": "Debug"
        }
    ]
}
